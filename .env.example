# ─── Kishaan Deepak — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── CORS — comma-separated list of allowed front-end origins ──────────────────
# Example for local dev + a deployed front-end:
# ALLOWED_ORIGINS=http://localhost:5000,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5000

# ── Groq API (required for chatbot) ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
